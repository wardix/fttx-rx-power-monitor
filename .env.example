# Example environment variables
DATABASE_URL=postgres://user:pass@localhost:5432/fttx
THIRD_PARTY_API_URL=https://third-party.example/command   # full URL for Rx power API (uses X-API-Key header)
SUBSCRIBER_API_BASE=https://third-party.example     # base URL for subscribers list (uses Bearer token)
X_API_KEY=your_api_key_here                           # API key for THIRD_PARTY_API_BASE
SUBSCRIBER_BEARER_TOKEN=your_subscriber_bearer_token_here   # Bearer token for SUBSCRIBER_API_BASE
OPERATOR_ID=your_operator_id_here                     # optional operator_id to include as request param for subscriber sync
REQUEST_DELAY_MS=200
SUBSCRIBER_SYNC_INTERVAL_HOURS=4
SUBSCRIBER_FRESHNESS_HOURS=24
RX_SAFE_THRESHOLD_DBM=-26
RX_SAFE_RECHECK_HOURS=4
METRICS_PORT=3000
